    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
            "env": {
                "PYTHONPATH": "/workspace/GaleMoE"
            }
        },      {
            "name": "Ablate Router",
            "type": "debugpy",
            "request": "launch",
            "program": "main2.py",
            "console": "integratedTerminal",
            "args": [
                "--svd_dir",
                "./svd_cache",
                "--layer_idx",
                "9",
                "--output_file",
                "results_layer5.json",
                "--num_samples","10"
            ],
            "env": {
                "PYTHONPATH": "/workspace/GaleMoE"
            }
        }
    ]
}